# =============================================================================
# ChessVision — Environment Variables
# Copy this file to .env and fill in values. Never commit .env to git.
# =============================================================================

# ── General ──────────────────────────────────────────────────────────────────
CHESSVISION_ENV=development          # development | production
LOG_LEVEL=debug                      # debug | info | warning | error
API_PORT=8006

# ── API Server ────────────────────────────────────────────────────────────────
WORKERS=2                            # uvicorn worker count (production only)
API_SECRET_KEY=change-me-in-production

# ── Model Paths (inside container) ───────────────────────────────────────────
MODEL_CORNER_PATH=/app/models/corner_detector/best.pt
MODEL_PIECE_PATH=/app/models/piece_detector/best.pt
MODEL_SQUARE_CLASSIFIER_PATH=/app/models/square_classifier/best.pt

# ── Inference Settings ────────────────────────────────────────────────────────
INFERENCE_DEVICE=cpu                 # cpu | cuda | mps (Apple Silicon)
PIECE_CONF_THRESHOLD=0.6             # YOLO confidence threshold for pieces
CORNER_CONF_THRESHOLD=0.4            # YOLO confidence threshold for corners
FRAME_CONSENSUS_COUNT=3              # Frames required to commit a new board state

# ── Calibration ───────────────────────────────────────────────────────────────
CALIBRATION_PATH=/app/data/calibration.json

# ── Stockfish (optional) ──────────────────────────────────────────────────────
STOCKFISH_PATH=/usr/local/bin/stockfish
STOCKFISH_DEPTH=15

# ── CORS (for browser clients) ────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
